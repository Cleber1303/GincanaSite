# Copie este arquivo para ".env" e preencha os valores.
# O ".env" nunca vai para o Git (esta protegido no .gitignore).

# 1. Conexao com o banco Postgres (copie do painel do Neon)
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# 2. Senha que o professor digita para entrar e lancar pontos
ADMIN_SENHA="troque-esta-senha"

# 3. Frase longa e aleatoria que assina os tokens de login
#    (invente algo grande, tipo 40+ caracteres sem sentido)
JWT_SECRET="troque-por-uma-frase-longa-aleatoria-qualquer"
